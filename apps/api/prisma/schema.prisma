// schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum RoleType {
  ADMIN
  USER
  CURATOR
}

model Role {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  RoleType @unique
  users User[]
}

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String    @unique
  passwordHash     String
  roleId           String    @db.Uuid
  role             Role      @relation(fields: [roleId], references: [id])
  platformLanguage String    @default("es-MX")
  region           String    @default("MX")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  projects         Project[]
  curatorProfile    Curator?
}

model Project {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @db.Uuid
  user               User     @relation(fields: [userId], references: [id])
  type               String   // PERSONAL, FAMILIAR, EMPRESARIAL, PROFESIONAL
  title              String
  description        String?
  primaryLanguage    String   @default("es-MX")
  secondaryLanguages String[]
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  
  assets             Asset[]
  interviews         Interview[]
  books              Book[]
  memories           Memory[]
}

model Asset {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId          String   @db.Uuid
  project            Project  @relation(fields: [projectId], references: [id])
  type               String   // PHOTO, VIDEO, AUDIO, DOCUMENT
  fileUrl            String   // MinIO object path
  bucket             String
  languageCode       String?
  originalLanguage   String?
  translatedVersions Json?
  metadata           Json?
  createdAt          DateTime @default(now())
}

model Interview {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String       @db.Uuid
  project     Project      @relation(fields: [projectId], references: [id])
  title       String
  audioUrl    String?
  createdAt   DateTime     @default(now())
  transcripts Transcript[]
}

model Transcript {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String    @db.Uuid
  interview   Interview @relation(fields: [interviewId], references: [id])
  content     String
  startTime   Float?
  endTime     Float?
}

model Memory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id])
  content     String
  metadata    Json?
  embeddings  Embedding[]
}

model Embedding {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memoryId    String    @db.Uuid
  memory      Memory    @relation(fields: [memoryId], references: [id])
  vector      Unsupported("vector(1536)")?
}

// Story Builder
model Book {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  status      String    @default("DRAFT")
  chapters    Chapter[]
}

model Chapter {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookId      String    @db.Uuid
  book        Book      @relation(fields: [bookId], references: [id])
  title       String
  content     String?
  order       Int
}

model Person {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  relation    String?
}

model Event {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  date        DateTime?
  description String?
}

// Marketplace
model Curator {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @unique @db.Uuid
  user        User      @relation(fields: [userId], references: [id])
  bio         String?
  specialties String[]
  listings    MarketplaceListing[]
}

model MarketplaceListing {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curatorId   String    @db.Uuid
  curator     Curator   @relation(fields: [curatorId], references: [id])
  title       String
  description String
  price       Decimal
  reviews     Review[]
}

model Review {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId   String    @db.Uuid
  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  rating      Int
  comment     String?
}
